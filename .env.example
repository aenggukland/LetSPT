# LetSPT 환경 변수 예시
# 이 파일을 복사해 .env 로 만든 후 실제 값을 채워주세요
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=letSPT
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here

# JWT 시크릿 키 (필수)
# - 최소 32바이트 이상의 랜덤 문자열을 사용하세요
# - 생성 예시: openssl rand -base64 32
# - 절대 기본값/추측 가능한 값을 사용하지 마세요
JWT_SECRET=your-random-secret-key-must-be-at-least-32-bytes

# 프로필 이미지 업로드 경로 (기본값: uploads/profile)
# UPLOAD_DIR=uploads/profile
