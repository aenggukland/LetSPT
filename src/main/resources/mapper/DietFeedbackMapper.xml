<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aenggukland.letspt.dietfeedback.DietFeedbackMapper">

    <resultMap id="dietFeedbackResultMap" type="com.aenggukland.letspt.dietfeedback.DietFeedback">
        <id     property="feedbackId" column="feedback_id"/>
        <result property="boardId"    column="board_id"/>
        <result property="trainerId"  column="trainer_id"/>
        <result property="memberId"   column="member_id"/>
        <result property="type"       column="type"
                typeHandler="org.apache.ibatis.type.EnumTypeHandler"
                javaType="com.aenggukland.letspt.dietfeedback.DietFeedbackType"/>
        <result property="createdAt"  column="created_at"/>
        <result property="updatedAt"  column="updated_at"/>
    </resultMap>

    <!-- 피드백 단건 조회 -->
    <select id="findById" parameterType="long" resultMap="dietFeedbackResultMap">
        SELECT * FROM diet_feedback WHERE feedback_id = #{feedbackId}
    </select>

    <!-- 게시글+트레이너 조합으로 기존 피드백 조회 (중복 등록 방지) -->
    <select id="findByBoardAndTrainer" resultMap="dietFeedbackResultMap">
        SELECT * FROM diet_feedback
        WHERE board_id = #{boardId} AND trainer_id = #{trainerId}
    </select>

    <!-- 게시글별 피드백 목록 조회 (최신순) -->
    <select id="findByBoardId" parameterType="long"
            resultType="com.aenggukland.letspt.dietfeedback.DietFeedbackResponse">
        SELECT feedback_id, board_id, trainer_id, type, created_at
        FROM diet_feedback
        WHERE board_id = #{boardId}
        ORDER BY created_at DESC
    </select>

    <!-- 신규 피드백 저장 -->
    <insert id="save" parameterType="com.aenggukland.letspt.dietfeedback.DietFeedback"
            useGeneratedKeys="true" keyProperty="feedbackId">
        INSERT INTO diet_feedback (board_id, trainer_id, member_id, type)
        VALUES (#{boardId}, #{trainerId}, #{memberId}, #{type})
    </insert>

    <!-- 피드백 타입 수정 -->
    <update id="update">
        UPDATE diet_feedback
        SET type = #{type}, updated_at = CURRENT_TIMESTAMP
        WHERE feedback_id = #{feedbackId}
    </update>

    <!-- 피드백 삭제 -->
    <delete id="delete" parameterType="long">
        DELETE FROM diet_feedback WHERE feedback_id = #{feedbackId}
    </delete>

</mapper>
