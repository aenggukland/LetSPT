        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aenggukland.letspt.chat.ChatMapper">
    <insert id="makeChatRoom" parameterType="com.aenggukland.letspt.chat.ChatRoom">
        INSERT INTO chat_room (trainer_id, member_id)
