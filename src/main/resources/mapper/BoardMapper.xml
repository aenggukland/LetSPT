<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.aenggukland.letspt.board.BoardMapper">

    <!-- Board 엔티티 ResultMap: DB 컬럼(snake_case) → Java 필드(camelCase) 매핑
         category 컬럼은 EnumTypeHandler로 BoardCategory Enum 변환을 처리한다 -->
    <resultMap id="boardResultMap" type="com.aenggukland.letspt.board.Board">
        <id     property="boardId"   column="board_id"/>
        <result property="imageId"   column="image_id"/>
        <result property="authorId"  column="author_id"/>
        <result property="memberId"  column="member_id"/>
        <result property="category"  column="category"
                typeHandler="org.apache.ibatis.type.EnumTypeHandler"
                javaType="com.aenggukland.letspt.board.BoardCategory"/>
        <result property="title"     column="title"/>
        <result property="content"   column="content"/>
        <result property="isDeleted" column="is_deleted"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- boardId로 게시글 단건 조회 (삭제된 게시글 제외) -->
    <select id="findById" parameterType="long" resultMap="boardResultMap">
        SELECT * FROM board
        WHERE board_id = #{boardId}
          AND is_deleted = FALSE
    </select>

    <!-- 검색조건에 따른 게시물 목록 조회 (삭제된 게시글 제외) -->
    <select id="getBoardList" parameterType="com.aenggukland.letspt.board.BoardSearchReqeust" resultMap="boardResultMap">
        SELECT * FROM board
        WHERE category = #{category}
          AND is_deleted = FALSE
        <if test="searchCategory != null">
            <choose>
                <when test="searchCategory.name() == 'TITLE'">
                    AND title LIKE '%' || #{searchKeyword} || '%'
                </when>
                <when test="searchCategory.name() == 'CONTENT'">
                    AND content LIKE '%' || #{searchKeyword} || '%'
                </when>
                <when test="searchCategory.name() == 'AUTHOR'">
                    AND author_id IN (
                    SELECT member_id FROM member
                    WHERE name LIKE '%' || #{searchKeyword} || '%'
                    )
                </when>
            </choose>
        </if>
        ORDER BY created_at DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <!-- 마이페이지 LESSON 카드: 대상 회원(member_id) 기준 최근 N건 조회 -->
    <select id="findRecentLessonsByMemberId"
            resultType="com.aenggukland.letspt.board.BoardSummary">
        SELECT board_id, title, created_at
        FROM board
        WHERE category = 'LESSON'
          AND member_id = #{memberId}
          AND is_deleted = FALSE
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

    <!-- 마이페이지 DIET/EXERCISE 카드: 작성자(author_id)와 카테고리 기준 최근 N건 조회 -->
    <select id="findRecentByAuthor"
            resultType="com.aenggukland.letspt.board.BoardSummary">
        SELECT board_id, title, created_at
        FROM board
        WHERE category = #{category}
          AND author_id = #{authorId}
          AND is_deleted = FALSE
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

    <!-- LESSON 전체 목록: 대상 회원(member_id) 기준, 최신순 정렬 -->
    <select id="findAllLessonsByMemberId" parameterType="long" resultMap="boardResultMap">
        SELECT * FROM board
        WHERE category = 'LESSON'
          AND member_id = #{memberId}
          AND is_deleted = FALSE
        ORDER BY created_at DESC
    </select>

    <!-- 게시글 다건 조회 및 검색 -->
    <select id="findAllByAuthor" resultMap="boardResultMap">
        SELECT * FROM board
        WHERE category = #{category}
          AND author_id = #{authorId}
          AND is_deleted = FALSE
        ORDER BY created_at DESC
    </select>

    <!-- 새 게시글 저장: 생성된 board_id를 엔티티에 자동 주입 -->
    <insert id="save" parameterType="com.aenggukland.letspt.board.Board"
            useGeneratedKeys="true" keyProperty="boardId">
        INSERT INTO board (image_id, author_id, member_id, category, title, content)
        VALUES (#{imageId}, #{authorId}, #{memberId}, #{category}, #{title}, #{content})
    </insert>

    <!-- 게시글 부분 수정: null이 아닌 필드만 선택적으로 업데이트하고 updated_at을 갱신한다 -->
    <update id="update">
        UPDATE board
        <set>
            <if test="request.title != null">title = #{request.title},</if>
            <if test="request.content != null">content = #{request.content},</if>
            updated_at = CURRENT_TIMESTAMP
        </set>
        WHERE board_id = #{boardId}
          AND is_deleted = FALSE
    </update>

    <!-- 소프트 삭제: 물리 삭제 대신 is_deleted 플래그를 설정한다 -->
    <update id="softDelete" parameterType="long">
        UPDATE board
        SET is_deleted = TRUE,
            updated_at = CURRENT_TIMESTAMP
        WHERE board_id = #{boardId}
    </update>

</mapper>
